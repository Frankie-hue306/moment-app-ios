/*
 * ========================================
 *  美甲 DIY 小程序 — 设计令牌
 *  Apple HIG · iOS 原生质感
 * ========================================
 */

page {
  /* ===== 品牌色 ===== */
  --color-accent:             #FF6B8A;
  --color-accent-light:       #FFB3C6;
  --color-accent-bg:          #FFF0F3;

  /* iOS 系统色 */
  --color-red:                #FF3B30;
  --color-orange:             #FF9500;
  --color-green:              #34C759;
  --color-blue:               #007AFF;

  /* ===== 背景 ===== */
  --color-bg:                 #F2F2F7;    /* iOS 系统分组背景 */
  --color-bg-card:            #FFFFFF;    /* 卡片/列表背景 */
  --color-bg-secondary:       #F2F2F7;    /* 分组内背景 */
  --color-bg-tertiary:        #E5E5EA;    /* 填充 */

  /* ===== 分隔线 ===== */
  --color-separator:          #C6C6C8;    /* 非不透明分隔 */
  --color-separator-opaque:   #E5E5EA;    /* 不透明分隔 */

  /* ===== 文字 ===== */
  --color-text-primary:       #000000;
  --color-text-secondary:     #3C3C43;
  --color-text-tertiary:      #8E8E93;
  --color-text-quaternary:    #C7C7CC;
  --color-text-inverse:       #FFFFFF;

  /* ===== 圆角 ===== */
  --radius-sm:                6rpx;
  --radius-md:                10rpx;
  --radius-lg:                13rpx;
  --radius-xl:                20rpx;
  --radius-full:              9999rpx;

  /* ===== 阴影 ===== */
  --shadow-drop:              0 2rpx 16rpx rgba(0,0,0,0.08);
  --shadow-float:             0 8rpx 32rpx rgba(0,0,0,0.12);

  /* ===== 间距 ===== */
  --spacing-xs:               8rpx;
  --spacing-sm:               12rpx;
  --spacing-md:               16rpx;
  --spacing-lg:               20rpx;
  --spacing-xl:               32rpx;

  /* ===== 字体 ===== */
  --font-family:              -apple-system, 'SF Pro Text', 'PingFang SC',
                              'Helvetica Neue', sans-serif;
  --font-family-display:      -apple-system, 'SF Pro Display', 'PingFang SC',
                              sans-serif;
  --font-family-number:       -apple-system, 'SF Mono', 'Menlo', monospace;

  /* 字号（Apple 风格） */
  --font-size-caption:        22rpx;   /* caption2 */
  --font-size-footnote:       24rpx;   /* footnote */
  --font-size-subhead:        26rpx;   /* subheadline */
  --font-size-callout:        28rpx;   /* callout */
  --font-size-body:           30rpx;   /* body */
  --font-size-headline:       32rpx;   /* headline */
  --font-size-title3:         36rpx;   /* title3 */
  --font-size-title2:         40rpx;   /* title2 */
  --font-size-title1:         48rpx;   /* title1 */
  --font-size-large-title:    56rpx;   /* largeTitle */

  /* 字重 */
  --font-weight-regular:      400;
  --font-weight-medium:       500;
  --font-weight-semibold:     590;     /* SF 特有 */
  --font-weight-bold:         700;

  /* 行高 */
  --line-height-tight:        1.2;
  --line-height-normal:       1.4;
  --line-height-relaxed:      1.6;

  /* ===== 动画 ===== */
  --transition-fast:          0.15s cubic-bezier(0.25, 0.1, 0.25, 1);
  --transition-normal:        0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
  --transition-slow:          0.35s cubic-bezier(0.25, 0.1, 0.25, 1);

  /* ===== 安全区 ===== */
  --safe-area-bottom:         0rpx;
  --safe-area-top:            0rpx;

  /* ===== 组件级令牌 ===== */
  --navbar-height:            88rpx;
  --tabbar-height:            98rpx;
}
