/* RealNail — Apple Minimalist */
page{--accent:#DDBEA9;--bg:#FFF;--bg2:#F5F5F5;--sep:#EBEBEB;--t1:#1C1C1E;--t2:#6D6D72;--t3:#B0B0B0;--r-sm:8rpx;--r:16rpx;--r-full:40rpx;--font:-apple-system,'SF Pro Text','PingFang SC',sans-serif;background:var(--bg);font-family:var(--font);color:var(--t1);-webkit-font-smoothing:antialiased;font-size:28rpx}
.fx{display:flex}.fc{align-items:center}.fb{justify-content:space-between}.f1{flex:1}.ell{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.btn{display:flex;align-items:center;justify-content:center;height:88rpx;border-radius:44rpx;font-size:28rpx;font-weight:590;border:none}
.btn-fill{background:var(--accent);color:#FFF}.btn-fill:active{opacity:.8}
.btn-line{background:transparent;color:var(--accent);border:1.5px solid var(--accent)}
.empty{display:flex;flex-direction:column;align-items:center;padding-top:160rpx}.empty-ico{font-size:64rpx;margin-bottom:24rpx}.empty-t{font-size:30rpx;font-weight:600}.empty-d{font-size:26rpx;color:var(--t3);margin-top:8rpx}
@keyframes up{from{opacity:0;transform:translateY(12rpx)}to{opacity:1;transform:translateY(0)}}.anim-up{animation:up .35s ease}
.safe-b{padding-bottom:env(safe-area-inset-bottom,0rpx)}
