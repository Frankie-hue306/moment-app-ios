<!--
  款式详情页
  专业色板 Hero · Apple HIG 风格
-->
<view class="page-detail" wx:if="{{style}}">

  <!-- ====== Hero — 色板展示 ====== -->
  <view class="detail-hero" style="background: {{style.colors[3] || style.colors[0]}}15;" bindtap="onPreviewImage">
    <view class="detail-swatch-stack">
      <view class="detail-swatch" wx:for="{{style.detailColors || style.colors}}" wx:for-item="c" wx:key="*this" wx:if="{{index < 5}}" style="background: {{c}};">
        <view class="detail-swatch-shine"></view>
        <text class="detail-swatch-hex" wx:if="{{index === 0}}">{{c}}</text>
      </view>
    </view>
    <view class="hero-badge" wx:if="{{style.isHot}}">HOT</view>
    <view class="hero-badge new" wx:elif="{{style.isNew}}">NEW</view>
    <view class="hero-vibe" wx:if="{{style.vibe}}">{{style.vibe}}</view>
  </view>

  <!-- ====== 内容 ====== -->
  <view class="detail-body">

    <!-- 标题行 -->
    <view class="detail-header flex-between">
      <view class="flex-1">
        <text class="detail-name">{{style.name}}</text>
        <text class="detail-desc">{{style.description}}</text>
      </view>
      <view class="fav-btn {{isFavorited ? 'active' : ''}}" bindtap="onToggleFavorite">
        <text>{{isFavorited ? '❤️' : '🤍'}}</text>
      </view>
    </view>

    <!-- 标签 -->
    <view class="detail-tags">
      <text class="detail-tag" wx:for="{{style.tags}}" wx:key="*this">{{item}}</text>
    </view>

    <!-- 信息卡 -->
    <view class="info-cards">
      <view class="info-card">
        <text class="info-icon">⏱</text>
        <text class="info-value">{{style.timeEstimate}}</text>
        <text class="info-label">预计耗时</text>
      </view>
      <view class="info-card">
        <text class="info-icon">📊</text>
        <text class="info-value">{{style.difficultyLabel}}</text>
        <text class="info-label">难度</text>
      </view>
      <view class="info-card">
        <text class="info-icon">❤️</text>
        <text class="info-value">{{style.likes}}</text>
        <text class="info-label">喜欢</text>
      </view>
    </view>

    <!-- 配色方案 -->
    <view class="detail-section">
      <text class="section-title">配色方案</text>
      <view class="color-showcase">
        <view class="color-block" wx:for="{{style.detailColors || style.colors}}" wx:for-item="c" wx:key="*this" style="background: {{c}};">
          <text class="color-hex">{{c}}</text>
        </view>
      </view>
    </view>

    <!-- 风格标签 -->
    <view class="detail-section" wx:if="{{style.vibe}}">
      <text class="section-title">风格</text>
      <text class="vibe-text">{{style.vibe}}</text>
    </view>

    <!-- 设计步骤 -->
    <view class="detail-section">
      <text class="section-title">设计步骤（{{style.steps}}步）</text>
      <view class="step-list">
        <view class="step-row" wx:for="{{style.steps}}" wx:key="*this">
          <view class="step-dot">{{index + 1}}</view>
          <text class="step-text">
            {{index === 0 ? '底色打底' : index === style.steps - 1 ? '封层保护' : '图案/配色层'}}
          </text>
        </view>
      </view>
    </view>

    <!-- 相似推荐 -->
    <view class="detail-section">
      <text class="section-title">相似推荐</text>
      <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="similar-scroll">
        <view class="similar-card" wx:for="{{similarStyles}}" wx:key="_id" bindtap="onSimilarTap" data-id="{{item._id}}">
          <view class="similar-swatch-stack" style="background: {{item.colors[3] || item.colors[0]}}15;">
            <view class="sim-swatch" wx:for="{{item.colors}}" wx:for-item="c" wx:key="*this" wx:if="{{index < 3}}" style="background: {{c}};"></view>
          </view>
          <text class="similar-name text-ellipsis">{{item.name}}</text>
          <text class="similar-likes">❤ {{item.likes}}</text>
        </view>
      </scroll-view>
    </view>

    <view class="detail-bottom"></view>
  </view>

  <!-- ====== 底部操作栏 ====== -->
  <view class="detail-bar">
    <view class="bar-btn secondary" bindtap="onStartDIY"><text>🎨 DIY</text></view>
    <view class="bar-btn primary" bindtap="onTryOn"><text>✨ 开始试戴</text></view>
  </view>
</view>
