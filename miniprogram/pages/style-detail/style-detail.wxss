/*
 * 款式详情页 — Apple HIG 风格
 */

.page-detail {
  min-height: 100vh;
  background: var(--color-bg);
}

/* ===== Hero — 色板展示 ===== */
.detail-hero {
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.detail-swatch-stack {
  width: 40%;
  height: 65%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.detail-swatch {
  flex: 1;
  border-radius: 8rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-swatch:first-child { border-radius: 14rpx 14rpx 6rpx 6rpx; }
.detail-swatch:last-child  { border-radius: 6rpx 6rpx 14rpx 14rpx; }
.detail-swatch-shine {
  position: absolute;
  top: 0; left: 10%; width: 25%; height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0.35), rgba(255,255,255,0.02));
  border-radius: 50%;
  transform: skewX(-8deg);
}
.detail-swatch-hex {
  position: absolute;
  bottom: 4rpx; left: 8rpx;
  font-size: 18rpx; color: rgba(255,255,255,0.9);
  font-family: var(--font-family-number);
}
.hero-badge {
  position: absolute;
  top: var(--spacing-lg);
  left: var(--spacing-lg);
  padding: 4rpx 14rpx;
  background: var(--color-accent);
  border-radius: var(--radius-full);
  color: #fff;
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-semibold);
  letter-spacing: 0.3rpx;
}
.hero-vibe {
  position: absolute;
  bottom: var(--spacing-lg);
  font-size: var(--font-size-footnote);
  color: var(--color-text-tertiary);
  background: var(--color-bg-card);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

/* ===== 内容区 ===== */
.detail-body {
  padding: var(--spacing-lg);
  margin-top: -20rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  position: relative;
}
.detail-header {
  margin-bottom: var(--spacing-md);
}
.detail-name {
  font-size: var(--font-size-title2);
  font-weight: var(--font-weight-bold);
  letter-spacing: -0.3rpx;
  display: block;
}
.detail-desc {
  font-size: var(--font-size-subhead);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  display: block;
}
.fav-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: var(--color-bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-headline);
  flex-shrink: 0;
}
.fav-btn.active {
  background: var(--color-accent-bg);
}

/* 标签 */
.detail-tags {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
  flex-wrap: wrap;
}
.detail-tag {
  font-size: var(--font-size-footnote);
  color: var(--color-accent);
  padding: 4rpx 14rpx;
  background: var(--color-accent-bg);
  border-radius: var(--radius-full);
}

/* 信息卡 */
.info-cards {
  display: flex;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-xl);
}
.info-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-md);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
}
.info-icon {
  font-size: 28rpx;
}
.info-value {
  font-size: var(--font-size-headline);
  font-weight: var(--font-weight-semibold);
  margin: 4rpx 0;
}
.info-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

/* 区块 */
.detail-section {
  margin-bottom: var(--spacing-xl);
}
.section-title {
  font-size: var(--font-size-headline);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--spacing-md);
  display: block;
}

/* 配色 */
.color-showcase {
  display: flex;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
}
.color-block {
  flex: 1;
  min-width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: flex-end;
  padding: 4rpx;
}
.color-hex {
  font-size: 16rpx;
  color: rgba(255,255,255,0.85);
  padding: 2rpx 6rpx;
  border-radius: 4rpx;
  background: rgba(0,0,0,0.15);
}

/* 步骤 */
.step-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}
.step-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}
.step-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: var(--color-accent);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-semibold);
  flex-shrink: 0;
}
.step-text {
  font-size: var(--font-size-subhead);
  color: var(--color-text-secondary);
}

/* 风格标签 */
.vibe-text {
  font-size: var(--font-size-callout);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

/* 相似推荐 */
.similar-scroll {
  white-space: nowrap;
}
.similar-card {
  display: inline-flex;
  flex-direction: column;
  width: 170rpx;
  margin-right: var(--spacing-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.similar-card:last-child { margin-right: 0; }
.similar-swatch-stack {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 20rpx;
}
.sim-swatch {
  flex: 1;
  border-radius: 4rpx;
  min-height: 80%;
}
.sim-swatch:first-child { border-radius: 8rpx 8rpx 3rpx 3rpx; }
.sim-swatch:last-child  { border-radius: 3rpx 3rpx 8rpx 8rpx; }
.similar-name {
  font-size: var(--font-size-footnote);
  padding: var(--spacing-sm) var(--spacing-sm) 2rpx;
  display: block;
}
.similar-likes {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
  padding: 2rpx var(--spacing-sm) var(--spacing-sm);
}

.detail-bottom {
  height: 160rpx;
}

/* 底部栏 */
.detail-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--spacing-md);
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + var(--safe-area-bottom));
  background: var(--color-bg-card);
  z-index: 100;
}
.bar-btn {
  height: 88rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
}
.bar-btn.secondary {
  width: 170rpx;
  flex-shrink: 0;
  border: 1.5px solid var(--color-accent);
  color: var(--color-accent);
}
.bar-btn.primary {
  flex: 1;
  background: var(--color-accent);
  color: #fff;
}
