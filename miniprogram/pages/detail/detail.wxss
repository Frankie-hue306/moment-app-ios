.pg{min-height:100vh;background:#FFF}
.hero{height:420rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative}.hero-nails{display:flex;gap:16rpx}.hn{width:96rpx;height:152rpx;border-radius:44% 44% 34% 34%/14% 14% 22% 22%;position:relative;overflow:hidden}.hn-shine{position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse 55% 35% at 50% 22%,rgba(255,255,255,.4),transparent 60%);border-radius:inherit}.hero-price{position:absolute;bottom:24rpx;font-size:48rpx;font-weight:700}
.body{padding:24rpx;margin-top:-20rpx;background:#FFF;border-radius:20rpx 20rpx 0 0;position:relative}.body-name{font-size:40rpx;font-weight:700}.body-cat{font-size:24rpx;color:var(--t3)}.body-desc{font-size:26rpx;color:var(--t2);line-height:1.5;margin:16rpx 0;display:block}
.tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:24rpx}.t{padding:6rpx 18rpx;border-radius:32rpx;font-size:22rpx;background:#F5F5F5;color:var(--t2)}
.sec-t{font-size:28rpx;font-weight:600;margin-bottom:16rpx;display:block}
.colors{display:flex;gap:12rpx;margin-bottom:28rpx}.co{flex:1;min-width:70rpx;height:70rpx;border-radius:12rpx;display:flex;align-items:flex-end;padding:6rpx}.co-hex{font-size:22rpx;color:rgba(255,255,255,.9);background:rgba(0,0,0,.25);padding:2rpx 8rpx;border-radius:6rpx}
.sim-scroll{white-space:nowrap;margin-bottom:28rpx}.sim{display:inline-flex;flex-direction:column;width:150rpx;margin-right:16rpx}.sim:last-child{margin-right:0}.sim-prev{height:150rpx;border-radius:12rpx;display:flex;align-items:center;justify-content:center;margin-bottom:8rpx}.sim-nail{width:54rpx;height:86rpx;border-radius:44% 44% 34% 34%/14% 14% 22% 22%;position:relative;overflow:hidden}.sim-shine{position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse 60% 40% at 50% 22%,rgba(255,255,255,.4),transparent 60%);border-radius:inherit}.sim-name{font-size:22rpx;display:block}
.bot-bar{position:fixed;bottom:0;left:0;right:0;display:flex;gap:16rpx;padding:20rpx 24rpx;padding-bottom:calc(20rpx + env(safe-area-inset-bottom,0rpx));background:rgba(255,255,255,.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:.5px solid var(--sep);z-index:100}
