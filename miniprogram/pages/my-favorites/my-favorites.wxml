<!--
  我的收藏页
-->
<view class="page-favorites">

  <!-- ====== 头部 ====== -->
  <view class="fav-header">
    <text class="text-secondary">{{favorites.length}} 个收藏</text>
    <view class="header-right">
      <view class="action-link" bindtap="onToggleEdit" wx:if="{{!isEmpty}}">
        <text>{{editMode ? '完成' : '管理'}}</text>
      </view>
      <view class="action-link" bindtap="onBrowseGallery">
        <text>去发现更多</text>
      </view>
    </view>
  </view>

  <!-- ====== 编辑栏 ====== -->
  <view class="edit-bar" wx:if="{{editMode && !isEmpty}}">
    <text class="text-secondary">已选 {{selectedIds.length}} 项</text>
    <view class="btn-secondary small danger" bindtap="onRemoveSelected">
      <text>取消收藏</text>
    </view>
  </view>

  <!-- ====== 收藏列表 ====== -->
  <view class="fav-list" wx:if="{{!loading && !isEmpty}}">
    <view
      class="fav-card animate-fade-in {{editMode ? 'edit-mode' : ''}} {{selectedIds.indexOf(item._id) > -1 ? 'selected' : ''}}"
      wx:for="{{favorites}}"
      wx:key="_id"
      bindtap="{{editMode ? 'onSelectItem' : 'onViewDetail'}}"
      data-id="{{item._id}}"
    >
      <!-- 预览 -->
      <view class="fav-card-preview" style="background: linear-gradient(135deg, {{item.primaryColor}}20, {{item.primaryColor}}35);">
        <text class="fav-emoji">{{item.emoji || '💅'}}</text>
        <view class="select-check" wx:if="{{editMode && selectedIds.indexOf(item._id) > -1}}">
          <text>✓</text>
        </view>
      </view>

      <!-- 信息 -->
      <view class="fav-card-info">
        <view class="flex-1">
          <text class="fav-name">{{item.name}}</text>
          <view class="fav-tags">
            <text class="fav-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 3}}">{{tag}}</text>
          </view>
        </view>

        <!-- 操作 -->
        <view class="fav-actions" wx:if="{{!editMode}}">
          <view class="fav-action-btn" catchtap="onQuickUnfavorite" data-id="{{item._id}}">
            <text>❤️</text>
          </view>
          <text class="text-arrow text-tertiary">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 空状态 ====== -->
  <view class="empty-state" wx:if="{{!loading && isEmpty}}">
    <text class="empty-icon">🤍</text>
    <text class="empty-title">还没有收藏</text>
    <text class="empty-desc text-secondary">浏览图库，收藏你喜欢的美甲款式</text>
    <view class="btn-primary" bindtap="onBrowseGallery">
      <text>去图库看看</text>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text class="text-tertiary">加载中...</text>
  </view>
</view>
