/*
 * 我的收藏页 — Apple HIG 风格
 */

.page-favorites {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 头部 */
.fav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg);
}
.header-right {
  display: flex;
  gap: var(--spacing-xl);
}
.action-link {
  font-size: var(--font-size-subhead);
  color: var(--color-accent);
}

/* 编辑栏 */
.edit-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--color-bg-secondary);
}
.btn-outline.small {
  height: 56rpx;
  padding: 0 var(--spacing-lg);
  font-size: var(--font-size-footnote);
}
.btn-outline.small.danger {
  border-color: var(--color-red);
  color: var(--color-red);
}

/* 收藏列表 */
.fav-list {
  padding: var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}
.fav-card {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.fav-card.selected {
  background: var(--color-accent-bg);
}
.fav-card-preview {
  width: 150rpx;
  min-height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}
.fav-emoji {
  font-size: 44rpx;
}
.select-check {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: var(--color-accent);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-semibold);
}
.fav-card-info {
  flex: 1;
  display: flex;
  align-items: center;
  padding: var(--spacing-md);
  gap: var(--spacing-sm);
}
.fav-name {
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
  display: block;
  margin-bottom: 4rpx;
}
.fav-tags {
  display: flex;
  gap: 4rpx;
  flex-wrap: wrap;
}
.fav-tag {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
  padding: 2rpx 8rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-full);
}
.text-arrow {
  font-size: var(--font-size-headline);
  color: var(--color-text-quaternary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 180rpx;
}
.empty-icon {
  font-size: 88rpx;
  margin-bottom: var(--spacing-lg);
}
.empty-title {
  font-size: var(--font-size-title3);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--spacing-sm);
}
.empty-desc {
  font-size: var(--font-size-subhead);
  color: var(--color-text-tertiary);
  margin-bottom: var(--spacing-xl);
}

.loading-state {
  text-align: center;
  padding-top: 180rpx;
  font-size: var(--font-size-subhead);
  color: var(--color-text-tertiary);
}
