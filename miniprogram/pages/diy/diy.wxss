/*
 * DIY 设计页 — Apple HIG 风格
 */

.page-diy {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

/* ===== 工具切换 ===== */
.diy-toolbar {
  display: flex;
  justify-content: space-around;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
}
.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-md);
  opacity: 0.4;
}
.tool-item.active {
  opacity: 1;
  background: var(--color-accent-bg);
}
.tool-icon {
  font-size: var(--font-size-headline);
}
.tool-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  margin-top: 2rpx;
}
.tool-item.active .tool-label {
  color: var(--color-accent);
  font-weight: var(--font-weight-semibold);
}

/* ===== 画布 ===== */
.canvas-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
}
.nail-canvas {
  width: 320rpx;
  height: 440rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.nail-shape {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}
.canvas-element {
  position: absolute;
  font-size: 44rpx;
  pointer-events: none;
}
.canvas-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}
.hint-icon {
  font-size: 40rpx;
  opacity: 0.25;
}
.hint-text {
  font-size: var(--font-size-footnote);
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-sm);
}

/* ===== 甲型选择 ===== */
.shape-selector {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-md);
  padding: var(--spacing-sm);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
}
.selector-label {
  font-size: var(--font-size-footnote);
  color: var(--color-text-tertiary);
  white-space: nowrap;
}
.shape-option {
  font-size: var(--font-size-footnote);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-secondary);
  color: var(--color-text-secondary);
}
.shape-option.active {
  background: var(--color-accent);
  color: #fff;
}

/* ===== 底色选择 ===== */
.color-strip {
  display: flex;
  align-items: center;
  margin-top: var(--spacing-sm);
  gap: var(--spacing-sm);
  width: 100%;
}
.color-scroll {
  flex: 1;
  white-space: nowrap;
}
.base-color-item {
  display: inline-block;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  margin-right: var(--spacing-sm);
  border: 2px solid transparent;
}
.base-color-item.active {
  border-color: var(--color-accent);
}

/* ===== 底部面板 ===== */
.tool-panel {
  height: 300rpx;
  background: var(--color-bg-card);
  overflow: hidden;
}
.panel-content {
  padding: var(--spacing-md) var(--spacing-lg);
  height: 100%;
}
.panel-title {
  font-size: var(--font-size-subhead);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--spacing-sm);
  display: block;
}

/* 最近颜色 */
.recent-colors {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}
.recent-color {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  border: 2px solid transparent;
}
.recent-color.active {
  border-color: var(--color-accent);
}

/* 色板 */
.palette-scroll {
  height: 200rpx;
}
.palette-group {
  margin-bottom: var(--spacing-sm);
}
.palette-name {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
  margin-bottom: 6rpx;
  display: block;
}
.palette-colors {
  display: flex;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
}
.palette-color {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-md);
  border: 2px solid transparent;
}
.palette-color.active {
  border-color: var(--color-accent);
}

/* 贴纸/装饰网格 */
.item-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}
.grid-item {
  width: calc(25% - 9rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-sm);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}
.grid-item:active {
  background: var(--color-accent-bg);
}
.grid-emoji {
  font-size: 36rpx;
}
.grid-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* 擦除 */
.eraser-actions {
  display: flex;
  gap: var(--spacing-md);
}
.eraser-actions .btn-outline {
  flex: 1;
  height: 72rpx;
  font-size: var(--font-size-subhead);
}

/* ===== 底部操作栏 ===== */
.diy-bottom-bar {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-sm) + var(--safe-area-bottom));
  background: var(--color-bg-card);
  gap: var(--spacing-md);
}
.bottom-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: var(--color-bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-callout);
}
.bottom-count {
  flex: 1;
  font-size: var(--font-size-footnote);
  color: var(--color-text-tertiary);
}
.bottom-export {
  height: 68rpx;
  padding: 0 var(--spacing-xl);
  font-size: var(--font-size-subhead);
}

/* ===== 导出弹窗 ===== */
.export-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.35);
  z-index: 200;
  display: none;
  align-items: flex-end;
  justify-content: center;
}
.export-modal.show {
  display: flex;
}
.export-sheet {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--spacing-xl) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-xl) + var(--safe-area-bottom));
}
.export-title {
  font-size: var(--font-size-headline);
  font-weight: var(--font-weight-semibold);
  text-align: center;
  margin-bottom: var(--spacing-lg);
}
.export-input {
  margin-bottom: var(--spacing-lg);
  width: 100%;
  box-sizing: border-box;
}
