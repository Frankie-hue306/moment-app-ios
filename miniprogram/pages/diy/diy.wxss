.pg{min-height:100vh;background:#FFF;display:flex;flex-direction:column}
.nav{padding:0 24rpx}.nav-t{font-size:40rpx;font-weight:700;letter-spacing:-.5rpx;line-height:88rpx}

/* 预览 */
.preview{display:flex;align-items:center;justify-content:center;padding:48rpx 0}
.pv-nail{position:relative;overflow:hidden;transition:all .35s ease}
.pv-shine{position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse 60% 40% at 50% 22%,rgba(255,255,255,.35),transparent 60%)}
.pv-decor{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:56rpx}

/* 步骤指示 */
.steps{display:flex;align-items:center;justify-content:center;padding:0 48rpx;margin-bottom:32rpx;gap:0}
.st{display:flex;flex-direction:column;align-items:center;gap:6rpx}
.st-n{width:48rpx;height:48rpx;border-radius:24rpx;background:#F5F5F5;color:var(--t3);display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:600}
.st.on .st-n{background:var(--accent);color:#FFF}.st-l{font-size:22rpx;color:var(--t3)}.st.on .st-l{color:var(--accent);font-weight:600}
.st-line{flex:1;height:1.5px;background:#EBEBEB;margin:0 8rpx;margin-bottom:24rpx}

/* 选择行 */
.pick-row{padding:0 24rpx 24rpx;white-space:nowrap}
.pick{display:inline-flex;flex-direction:column;align-items:center;gap:8rpx;margin-right:20rpx;padding:8rpx;border-radius:var(--r);font-size:22rpx;color:var(--t2)}.pick.on{background:#FBF8F6}
.pk-nail{border:1.5px solid #EBEBEB}.pick.on .pk-nail{border-color:var(--accent)}
.pk-circle{width:72rpx;height:72rpx;border-radius:36rpx;border:3px solid transparent}.pick.on .pk-circle{border-color:var(--accent);transform:scale(1.1)}
.decor-pick{width:120rpx;white-space:normal}.decor-emoji{font-size:44rpx}.decor-name{font-size:20rpx;color:var(--t3)}

/* 装饰分类 */
.decor-panel{padding-bottom:16rpx}
.decor-cats{display:flex;padding:0 24rpx 16rpx;gap:8rpx}.dc{padding:10rpx 24rpx;border-radius:40rpx;font-size:24rpx;color:var(--t2);background:#F5F5F5}.dc.on{background:var(--accent);color:#FFF;font-weight:600}

.step-btns{display:flex;gap:16rpx;padding:16rpx 24rpx;padding-bottom:calc(16rpx + env(safe-area-inset-bottom,0rpx))}
.bot{height:calc(98rpx + 32rpx)}
