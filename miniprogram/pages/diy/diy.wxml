<!-- DIY工坊 — 三步点击式 -->
<view class="pg">
  <view class="nav" style="padding-top:{{sH}}px"><text class="nav-t">DIY工坊</text></view>

  <!-- 预览区 -->
  <view class="preview">
    <view class="pv-nail" style="width:{{shape.w*2}}rpx;height:{{shape.h*2}}rpx;border-radius:{{shape.r}};background:{{selColor}};box-shadow:0 8rpx 32rpx rgba(0,0,0,.08);">
      <view class="pv-shine"></view>
      <!-- 装饰层 -->
      <view class="pv-decor" wx:if="{{selDecor}}">{{selDecor.e}}</view>
    </view>
  </view>

  <!-- 步骤指示 -->
  <view class="steps">
    <view class="st {{step===1?'on':''}}"><text class="st-n">1</text><text class="st-l">选甲型</text></view>
    <view class="st-line"></view>
    <view class="st {{step===2?'on':''}}"><text class="st-n">2</text><text class="st-l">选颜色</text></view>
    <view class="st-line"></view>
    <view class="st {{step===3?'on':''}}"><text class="st-n">3</text><text class="st-l">加装饰</text></view>
  </view>

  <!-- 步骤1：选甲型 -->
  <scroll-view class="pick-row" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{step===1}}">
    <view class="pick {{selShape===item.k?'on':''}}" wx:for="{{shapes}}" wx:key="k" bindtap="onShape" data-k="{{item.k}}">
      <view class="pk-nail" style="width:64rpx;height:88rpx;border-radius:{{item.r}};background:var(--accent);"></view>
      <text>{{item.n}}</text>
    </view>
  </scroll-view>

  <!-- 步骤2：选颜色 -->
  <scroll-view class="pick-row" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{step===2}}">
    <view class="pick {{selColor===c?'on':''}}" wx:for="{{palette}}" wx:key="*this" bindtap="onColor" data-c="{{item}}">
      <view class="pk-circle" style="background:{{item}};"></view>
    </view>
  </scroll-view>

  <!-- 步骤3：加装饰 -->
  <view class="decor-panel" wx:if="{{step===3}}">
    <view class="decor-cats">
      <view class="dc {{decorCat===k?'on':''}}" wx:for="{{decorKeys}}" wx:key="*this" bindtap="onDecorCat" data-k="{{item}}">{{decorData[item].n}}</view>
    </view>
    <scroll-view class="pick-row" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="pick decor-pick {{selDecor&&selDecor.id===item.id?'on':''}}" wx:for="{{decorData[decorCat].items}}" wx:key="id" bindtap="onDecor" data-d="{{item}}">
        <text class="decor-emoji">{{item.e}}</text>
        <text class="decor-name">{{item.n}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 步骤切换 -->
  <view class="step-btns">
    <view class="btn btn-line" style="flex:1;height:72rpx;" bindtap="onPrev" wx:if="{{step>1}}">上一步</view>
    <view class="btn btn-fill" style="flex:1;height:72rpx;" bindtap="onNext">{{step===3?'完成设计':'下一步'}}</view>
  </view>

  <view class="bot"></view>
</view>
