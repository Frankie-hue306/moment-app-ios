/*
 * 我的设计页 — Apple HIG 风格
 */

.page-designs {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 头部 */
.designs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg);
}
.designs-count {
  font-size: var(--font-size-subhead);
  color: var(--color-text-secondary);
}
.header-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-lg);
}
.action-link {
  font-size: var(--font-size-subhead);
  color: var(--color-accent);
}
.btn-accent.small {
  height: 56rpx;
  padding: 0 var(--spacing-lg);
  font-size: var(--font-size-footnote);
}

/* 编辑栏 */
.edit-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--color-bg-secondary);
}
.edit-bar .text-secondary {
  font-size: var(--font-size-subhead);
}
.btn-outline.small {
  height: 56rpx;
  padding: 0 var(--spacing-lg);
  font-size: var(--font-size-footnote);
}
.btn-outline.small.danger {
  border-color: var(--color-red);
  color: var(--color-red);
}

/* 设计网格 */
.designs-grid {
  display: flex;
  flex-wrap: wrap;
  padding: var(--spacing-md);
  gap: var(--spacing-md);
}
.design-card {
  width: calc(33.33% - 8rpx);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.design-card.selected {
  background: var(--color-accent-bg);
}
.design-preview {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.design-emoji {
  font-size: 40rpx;
}
.select-check {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: var(--color-accent);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-semibold);
}
.design-info {
  padding: var(--spacing-sm);
}
.design-name {
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-semibold);
  display: block;
}
.design-meta {
  display: flex;
  gap: 4rpx;
  margin-top: 4rpx;
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 180rpx;
}
.empty-icon {
  font-size: 88rpx;
  margin-bottom: var(--spacing-lg);
}
.empty-title {
  font-size: var(--font-size-title3);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--spacing-sm);
}
.empty-desc {
  font-size: var(--font-size-subhead);
  color: var(--color-text-tertiary);
  margin-bottom: var(--spacing-xl);
}

.loading-state {
  text-align: center;
  padding-top: 180rpx;
  font-size: var(--font-size-subhead);
  color: var(--color-text-tertiary);
}
