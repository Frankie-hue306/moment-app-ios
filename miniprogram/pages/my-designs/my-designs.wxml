<!--
  我的设计页
-->
<view class="page-designs">

  <!-- ====== 顶部操作栏 ====== -->
  <view class="designs-header">
    <text class="designs-count text-secondary">{{designs.length}} 个设计</text>
    <view class="header-actions">
      <view class="action-link" bindtap="onToggleEdit" wx:if="{{!isEmpty}}">
        <text>{{editMode ? '完成' : '管理'}}</text>
      </view>
      <view class="btn-primary small" bindtap="onCreateNew">
        <text>+ 新建</text>
      </view>
    </view>
  </view>

  <!-- ====== 编辑模式操作栏 ====== -->
  <view class="edit-bar" wx:if="{{editMode && !isEmpty}}">
    <text class="text-secondary">已选 {{selectedIds.length}} 项</text>
    <view class="btn-secondary small danger" bindtap="onDeleteSelected">
      <text>删除</text>
    </view>
  </view>

  <!-- ====== 设计列表 ====== -->
  <view class="designs-grid" wx:if="{{!loading && !isEmpty}}">
    <view
      class="design-card {{editMode ? 'edit-mode' : ''}} {{selectedIds.indexOf(item._id) > -1 ? 'selected' : ''}}"
      wx:for="{{designs}}"
      wx:key="_id"
      bindtap="{{editMode ? 'onSelectDesign' : 'onOpenDesign'}}"
      data-id="{{item._id}}"
    >
      <view class="design-preview" style="background: linear-gradient(135deg, {{item.baseColor}}20, {{item.baseColor}}50);">
        <text class="design-emoji">{{item.emoji || '🎨'}}</text>
        <!-- 选中标记 -->
        <view class="select-check" wx:if="{{editMode && selectedIds.indexOf(item._id) > -1}}">
          <text>✓</text>
        </view>
      </view>
      <view class="design-info">
        <text class="design-name text-ellipsis">{{item.name}}</text>
        <view class="design-meta">
          <text class="text-tertiary">{{item.elementCount || 3}} 元素</text>
          <text class="text-tertiary">·</text>
          <text class="text-tertiary">{{item.createdAt}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 空状态 ====== -->
  <view class="empty-state" wx:if="{{!loading && isEmpty}}">
    <text class="empty-icon">🎨</text>
    <text class="empty-title">还没有设计作品</text>
    <text class="empty-desc text-secondary">开始你的第一个美甲设计吧！</text>
    <view class="btn-primary" bindtap="onCreateNew">
      <text>开始创作</text>
    </view>
  </view>

  <!-- ====== 加载中 ====== -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="text-tertiary">加载中...</text>
  </view>

</view>
