.pg{display:flex;flex-direction:column;height:100vh;background:#FFF}
.nav{padding:0 24rpx;background:#FFF;z-index:10}.nav-t{font-size:40rpx;font-weight:700;line-height:88rpx;letter-spacing:-.5rpx}
.cat-bar{padding:0 24rpx 16rpx;white-space:nowrap}.cat{display:inline-block;padding:10rpx 24rpx;margin-right:12rpx;border-radius:40rpx;font-size:26rpx;color:var(--t2);background:#F5F5F5}.cat.on{background:var(--accent);color:#FFF;font-weight:600}
.wf-scroll{flex:1}.wf{display:flex;padding:0 12rpx;gap:12rpx}.wf-c{flex:1;display:flex;flex-direction:column;gap:12rpx}
.card{background:#FFF;border-radius:var(--r);overflow:hidden}.card-img{width:100%;padding-top:133%;position:relative;display:flex;align-items:center;justify-content:center}
.ci-nail{width:74rpx;height:116rpx;border-radius:44% 44% 34% 34%/14% 14% 22% 22%;position:relative;overflow:hidden}.ci-shine{position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse 60% 40% at 50% 22%,rgba(255,255,255,.4),transparent 60%);border-radius:inherit}
.ci-price{position:absolute;bottom:10rpx;left:10rpx;font-size:20rpx;font-weight:600;color:var(--t1);background:rgba(255,255,255,.8);padding:4rpx 12rpx;border-radius:12rpx}
.card-info{padding:12rpx 14rpx 16rpx}.ci-name{font-size:24rpx;font-weight:500;display:block}.ci-cat{font-size:20rpx;color:var(--t3);margin-top:4rpx}
.bot{height:calc(98rpx + env(safe-area-inset-bottom,0rpx) + 32rpx)}
