/*
 * 图库页 — Apple HIG 风格
 */

.page-gallery {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

/* ===== 搜索 ===== */
.gallery-search {
  padding: var(--spacing-md) var(--spacing-lg) 0;
  background: var(--color-bg);
  flex-shrink: 0;
}
.search-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}
.search-input-wrap {
  flex: 1;
}
.search-field {
  height: 64rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-lg);
  font-size: var(--font-size-subhead);
}
.search-icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-callout);
}

/* ===== Tab ===== */
.gallery-tabs {
  display: flex;
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-bg);
  gap: 36rpx;
  flex-shrink: 0;
}
.gallery-tab {
  font-size: var(--font-size-headline);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-tertiary);
  padding: var(--spacing-xs) 0;
  position: relative;
}
.gallery-tab.active {
  color: var(--color-text-primary);
}
.gallery-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: var(--color-accent);
  border-radius: 2rpx;
}

/* ===== 分类 + 排序 ===== */
.gallery-bar {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-lg) var(--spacing-md);
  flex-shrink: 0;
}
.category-row {
  flex: 1;
  white-space: nowrap;
}
.category-chip {
  display: inline-block;
  padding: 6rpx 18rpx;
  margin-right: var(--spacing-sm);
  border-radius: var(--radius-full);
  font-size: var(--font-size-footnote);
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
}
.category-chip.active {
  background: var(--color-accent);
  color: #fff;
}
.sort-toggle {
  display: flex;
  gap: var(--spacing-xs);
}
.sort-chip {
  font-size: var(--font-size-footnote);
  color: var(--color-text-tertiary);
  padding: 4rpx 10rpx;
}
.sort-chip.active {
  color: var(--color-accent);
  font-weight: var(--font-weight-semibold);
}

/* ===== 瀑布流 ===== */
.waterfall-scroll {
  flex: 1;
}
.waterfall {
  display: flex;
  padding: 0 var(--spacing-md) var(--spacing-md);
  gap: var(--spacing-md);
}
.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

/* ===== 卡片 ===== */
.wf-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.wf-card-img {
  width: 100%;
  padding-top: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 色板堆叠 */
.wf-swatch-stack {
  width: 58%;
  height: 64%;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
  position: relative;
  z-index: 1;
}
.wf-swatch {
  flex: 1;
  border-radius: 6rpx;
  position: relative;
  overflow: hidden;
}
.wf-swatch:first-child {
  border-radius: 10rpx 10rpx 4rpx 4rpx;
}
.wf-swatch:last-child {
  border-radius: 4rpx 4rpx 10rpx 10rpx;
}
/* 光泽高光线 */
.wf-swatch-shine {
  position: absolute;
  top: 0;
  left: 10%;
  width: 30%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0.05) 100%);
  border-radius: 50%;
  transform: skewX(-8deg);
}

/* 分类标签 */
.wf-cat-tag {
  position: absolute;
  bottom: var(--spacing-sm);
  left: var(--spacing-sm);
  font-size: 18rpx;
  color: rgba(0,0,0,0.4);
  background: rgba(255,255,255,0.7);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-full);
  z-index: 2;
}
.wf-fav-btn {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  z-index: 2;
}
.wf-fav-btn.favorited {
  background: var(--color-accent);
}
.wf-badge {
  position: absolute;
  top: var(--spacing-sm);
  left: var(--spacing-sm);
  padding: 2rpx 8rpx;
  background: var(--color-accent);
  border-radius: var(--radius-full);
  font-size: 16rpx;
  color: #fff;
  z-index: 2;
  font-weight: var(--font-weight-semibold);
  letter-spacing: 0.3rpx;
}
.wf-card-body {
  padding: var(--spacing-sm) var(--spacing-sm) var(--spacing-sm);
}
.wf-card-name {
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-semibold);
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.wf-card-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
}
.wf-tag {
  font-size: var(--font-size-caption);
  color: var(--color-accent);
  padding: 2rpx 8rpx;
  background: var(--color-accent-bg);
  border-radius: var(--radius-full);
}
.wf-likes {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
  margin-left: auto;
}

.load-more,
.load-end {
  text-align: center;
  padding: var(--spacing-lg);
  font-size: var(--font-size-footnote);
  color: var(--color-text-tertiary);
}
.bottom-spacer {
  height: calc(var(--tabbar-height) + var(--safe-area-bottom));
}
