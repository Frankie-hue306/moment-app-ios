<!-- 款式库 — 双列瀑布流 + 分类筛选 -->
<view class="pg">
  <view class="nav" style="padding-top:{{sH}}px">
    <text class="nav-t">款式库</text>
  </view>
  <!-- 分类 -->
  <scroll-view class="cat-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="cat {{ac===item.k?'on':''}}" wx:for="{{cats}}" wx:key="k" bindtap="onCat" data-k="{{item.k}}">{{item.n}}</view>
  </scroll-view>
  <!-- 瀑布流 -->
  <scroll-view class="wf-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="wf">
      <view class="wf-c">
        <view class="card anim-up" wx:for="{{L}}" wx:key="id" bindtap="onTap" data-id="{{item.id}}">
          <view class="card-img" style="background:{{item.c[2]||item.c[0]}}08;">
            <view class="ci-nail" style="background:linear-gradient(180deg,{{item.c[0]}},{{item.c[1]||item.c[0]}});box-shadow:0 4rpx 14rpx rgba(0,0,0,.06);">
              <view class="ci-shine"></view>
            </view>
            <view class="ci-price">¥{{item.price}}</view>
          </view>
          <view class="card-info"><text class="ci-name ell">{{item.name}}</text><text class="ci-cat">{{item.catName}}</text></view>
        </view>
      </view>
      <view class="wf-c">
        <view class="card anim-up" wx:for="{{R}}" wx:key="id" bindtap="onTap" data-id="{{item.id}}">
          <view class="card-img" style="background:{{item.c[2]||item.c[0]}}08;">
            <view class="ci-nail" style="background:linear-gradient(180deg,{{item.c[0]}},{{item.c[1]||item.c[0]}});box-shadow:0 4rpx 14rpx rgba(0,0,0,.06);">
              <view class="ci-shine"></view>
            </view>
          </view>
          <view class="card-info"><text class="ci-name ell">{{item.name}}</text><text class="ci-cat">{{item.catName}}</text></view>
        </view>
      </view>
    </view>
    <view class="bot"></view>
  </scroll-view>
</view>
