.pg{display:flex;flex-direction:column;height:100vh;background:#FFF}
.top{display:flex;align-items:center;justify-content:space-between;padding:0 24rpx;height:88rpx}.top-t{font-size:32rpx;font-weight:600}.top-close{font-size:28rpx;color:var(--t3);width:56rpx;height:56rpx;display:flex;align-items:center;justify-content:center}

.hand-area{flex:1;position:relative;display:flex;align-items:center;justify-content:center;background:#FAFAFA;overflow:hidden}
.hand-img{width:100%;height:100%}
.nail-dots{position:absolute;top:0;left:0;right:0;bottom:0}.nd{position:absolute;width:60rpx;height:80rpx}.nd-dot{width:24rpx;height:16rpx;border-radius:10rpx}
.hand-status{position:absolute;top:120rpx;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.6);padding:8rpx 24rpx;border-radius:20rpx}.hand-status text{font-size:22rpx;color:#FFF}

.hand-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16rpx}.he-ico{font-size:88rpx}.he-t{font-size:34rpx;font-weight:700}.he-sub{font-size:24rpx;color:var(--t3)}

.c-strip{padding:16rpx 24rpx;white-space:nowrap;background:#FFF}.cs{display:inline-block;width:56rpx;height:56rpx;border-radius:28rpx;margin-right:14rpx;border:3px solid transparent}.cs.on{border-color:var(--accent);transform:scale(1.15)}

.act-bar{display:flex;align-items:center;gap:12rpx;padding:12rpx 24rpx;padding-bottom:calc(12rpx + env(safe-area-inset-bottom,0rpx));background:#FFF}
.ab-btn{width:64rpx;height:64rpx;border-radius:32rpx;background:#F5F5F5;display:flex;align-items:center;justify-content:center;font-size:28rpx}

.result{position:fixed;top:0;left:0;right:0;bottom:0;background:#FFF;z-index:50;display:flex;flex-direction:column;align-items:center;justify-content:center}.r-img{width:100%}.r-acts{position:absolute;bottom:0;left:0;right:0;display:flex;gap:24rpx;padding:32rpx;padding-bottom:calc(32rpx + env(safe-area-inset-bottom,0rpx))}
