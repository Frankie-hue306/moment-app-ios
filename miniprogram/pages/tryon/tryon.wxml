<!-- AI全自动试戴 -->
<view class="pg">
  <view class="top" style="padding-top:{{sH}}px">
    <text class="top-t">{{selStyle?selStyle.name:'AI试戴'}}</text>
    <view class="top-close" bindtap="onBack">✕</view>
  </view>

  <!-- 手部照片 -->
  <view class="hand-area" wx:if="{{hand}}">
    <image class="hand-img" src="{{hand}}" mode="aspectFit"></image>
    <!-- 检测结果标记 -->
    <view class="nail-dots" wx:if="{{detected}}">
      <view class="nd" wx:for="{{nails}}" wx:key="id" wx:if="{{item.v}}" style="left:{{item.x}}%;top:{{item.y}}%;transform:translate(-50%,-50%) rotate({{item.r}}deg) scale({{item.s}});">
        <view class="nd-dot" style="background:{{item.c}};box-shadow:0 0 0 3px rgba(255,255,255,.8),0 0 12px {{item.c}};"></view>
      </view>
    </view>
    <view class="hand-status" wx:if="{{status}}"><text>{{status}}</text></view>
  </view>

  <!-- 空状态 -->
  <view class="hand-empty" wx:if="{{!hand}}" bindtap="onCamera">
    <text class="he-ico">&#x1F590;</text>
    <text class="he-t">点击拍照</text>
    <text class="he-sub">AI自动识别指甲 · 一拍即合</text>
  </view>

  <!-- 颜色条 -->
  <scroll-view class="c-strip" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{hand}}">
    <view class="cs {{selColor===c?'on':''}}" wx:for="{{colors}}" wx:key="*this" bindtap="onColor" data-c="{{item}}" style="background:{{item}};"></view>
  </scroll-view>

  <!-- 操作 -->
  <view class="act-bar" wx:if="{{hand}}">
    <view class="ab-btn" bindtap="onCamera">拍照</view>
    <view class="ab-btn" bindtap="onDetect">检测</view>
    <view class="btn btn-fill" style="flex:2;height:72rpx;" bindtap="onComposite">合成效果</view>
  </view>

  <!-- 结果 -->
  <view class="result" wx:if="{{result}}">
    <image class="r-img" src="{{result}}" mode="widthFix"></image>
    <view class="r-acts">
      <view class="btn btn-fill" style="flex:1;" bindtap="onSave">保存</view>
      <view class="btn btn-line" style="flex:1;" bindtap="onRetry">重拍</view>
    </view>
  </view>

  <canvas type="2d" id="tc" style="position:fixed;left:0;top:0;width:750rpx;height:1000rpx;opacity:0;pointer-events:none;z-index:-1;"></canvas>
</view>
