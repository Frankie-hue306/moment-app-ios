/*
 * 首页 — Apple HIG 风格 · 专业色板卡
 */

.page-index {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

/* ===== 导航栏 ===== */
.navbar {
  background: var(--color-bg);
  position: sticky;
  top: 0;
  z-index: 100;
}
.navbar-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 var(--spacing-lg);
}
.navbar-brand {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.brand-icon {
  font-size: 36rpx;
}
.brand-name {
  font-size: var(--font-size-title3);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  letter-spacing: -0.3rpx;
}

/* ===== 搜索 ===== */
.search-section {
  padding: 0 var(--spacing-lg) var(--spacing-md);
  position: relative;
}
.search-box {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
}
.search-icon {
  font-size: var(--font-size-subhead);
  margin-right: var(--spacing-sm);
}
.search-input {
  flex: 1;
  font-size: var(--font-size-subhead);
  color: var(--color-text-primary);
}
.hot-keywords {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: var(--spacing-sm);
  gap: var(--spacing-xs);
}
.hot-label {
  font-size: var(--font-size-footnote);
  color: var(--color-text-tertiary);
}
.hot-keyword {
  font-size: var(--font-size-footnote);
  color: var(--color-accent);
  padding: 4rpx 14rpx;
  background: var(--color-accent-bg);
  border-radius: var(--radius-full);
}

.search-panel {
  position: absolute;
  left: var(--spacing-lg);
  right: var(--spacing-lg);
  top: 120rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-drop);
  padding: var(--spacing-xs);
  z-index: 50;
  max-height: 500rpx;
  overflow-y: auto;
}
.search-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
  gap: var(--spacing-sm);
}
.search-item:active { background: var(--color-bg-secondary); }
.search-item-color {
  width: 28rpx; height: 28rpx; border-radius: 14rpx; flex-shrink: 0;
}
.search-item-name {
  flex: 1; font-size: var(--font-size-subhead);
}
.search-item-tag {
  font-size: var(--font-size-caption); color: var(--color-text-tertiary);
}

/* ===== 主滚动 ===== */
.main-scroll { flex: 1; height: 0; }

/* ===== Banner ===== */
.banner-swiper {
  margin: 0 var(--spacing-lg) var(--spacing-md);
  height: 260rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
}
.banner-card {
  width: 100%; height: 100%;
  display: flex; align-items: center;
  padding: var(--spacing-xl);
  box-sizing: border-box;
}
.banner-text { display: flex; flex-direction: column; gap: 6rpx; }
.banner-emoji { font-size: 44rpx; }
.banner-title {
  font-size: var(--font-size-title2);
  font-weight: var(--font-weight-bold);
  letter-spacing: -0.3rpx;
}
.banner-subtitle {
  font-size: var(--font-size-subhead);
  color: var(--color-text-secondary);
}

/* ===== 快捷入口 ===== */
.quick-entries {
  display: flex; justify-content: space-around;
  padding: var(--spacing-sm) var(--spacing-lg) var(--spacing-lg);
}
.quick-entry {
  display: flex; flex-direction: column; align-items: center;
  gap: var(--spacing-sm);
}
.entry-icon-wrap {
  width: 104rpx; height: 104rpx;
  border-radius: var(--radius-xl);
  display: flex; align-items: center; justify-content: center;
}
.entry-icon { font-size: 44rpx; }
.entry-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

/* ===== 区块标题 ===== */
.section { padding: 0 var(--spacing-lg); margin-bottom: var(--spacing-lg); }
.section-header {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: var(--spacing-md);
}
.section-title {
  font-size: var(--font-size-title3);
  font-weight: var(--font-weight-bold);
  letter-spacing: -0.2rpx;
}
.section-more {
  font-size: var(--font-size-subhead); color: var(--color-accent);
}

/* ===== 热门横滑 ===== */
.hot-scroll { white-space: nowrap; }
.hot-card {
  display: inline-flex; flex-direction: column;
  width: 210rpx; margin-right: var(--spacing-md);
  background: var(--color-bg-card); border-radius: var(--radius-lg);
  overflow: hidden;
}
.hot-card:last-child { margin-right: 0; }
.hot-card-img {
  height: 190rpx; display: flex; align-items: center;
  justify-content: center; position: relative;
}
/* 热门卡片色板 */
.hot-swatch-stack {
  width: 55%; height: 55%;
  display: flex; flex-direction: column; gap: 4rpx;
}
.hot-swatch {
  flex: 1; border-radius: 4rpx;
}
.hot-swatch:first-child { border-radius: 8rpx 8rpx 3rpx 3rpx; }
.hot-swatch:last-child  { border-radius: 3rpx 3rpx 8rpx 8rpx; }
.hot-card-badge {
  position: absolute; top: var(--spacing-sm); right: var(--spacing-sm);
  background: var(--color-accent); border-radius: var(--radius-full);
  padding: 2rpx 10rpx;
}
.hot-card-badge text {
  font-size: 16rpx; color: #fff; font-weight: var(--font-weight-semibold);
}
.hot-card-info {
  padding: var(--spacing-sm) var(--spacing-md) var(--spacing-md);
}
.hot-card-name {
  font-size: var(--font-size-subhead); font-weight: var(--font-weight-semibold);
  display: block; margin-bottom: 4rpx;
}
.hot-card-meta { display: flex; justify-content: space-between; }
.hot-card-diff, .hot-card-likes {
  font-size: var(--font-size-caption); color: var(--color-text-tertiary);
}

/* ===== 分类 ===== */
.category-scroll { white-space: nowrap; }
.category-tag {
  display: inline-block;
  padding: var(--spacing-sm) var(--spacing-lg);
  margin-right: var(--spacing-sm);
  background: var(--color-bg-card);
  border-radius: var(--radius-full);
  font-size: var(--font-size-subhead);
  color: var(--color-text-secondary);
}
.category-tag.active { background: var(--color-accent); color: #fff; }

/* ===== 款式网格 ===== */
.style-grid {
  display: flex; flex-wrap: wrap;
  padding: 0 var(--spacing-lg); gap: var(--spacing-md);
}
.style-card {
  width: calc(50% - 6rpx);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg); overflow: hidden;
}
.style-card-preview {
  height: 200rpx; display: flex;
  align-items: center; justify-content: center;
  position: relative;
}
/* 网格卡片色板 */
.style-swatch-stack {
  width: 54%; height: 56%;
  display: flex; flex-direction: column; gap: 5rpx;
}
.style-swatch {
  flex: 1; border-radius: 5rpx; position: relative; overflow: hidden;
}
.style-swatch:first-child { border-radius: 10rpx 10rpx 4rpx 4rpx; }
.style-swatch:last-child  { border-radius: 4rpx 4rpx 10rpx 10rpx; }
.style-swatch-shine {
  position: absolute; top: 0; left: 8%; width: 28%; height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0.3), rgba(255,255,255,0.02));
  border-radius: 50%; transform: skewX(-6deg);
}
.style-card-body {
  padding: var(--spacing-sm) var(--spacing-md) var(--spacing-md);
}
.style-card-name {
  font-size: var(--font-size-subhead);
  font-weight: var(--font-weight-semibold);
  display: block; margin-bottom: 6rpx;
}
.style-card-footer {
  display: flex; justify-content: space-between; align-items: center;
}
.style-tags { display: flex; gap: 4rpx; }
.style-tag {
  font-size: var(--font-size-caption);
  color: var(--color-accent);
  padding: 2rpx 8rpx;
  background: var(--color-accent-bg);
  border-radius: var(--radius-full);
}
.style-likes {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

/* ===== 加载 ===== */
.load-more {
  display: flex; flex-direction: column; align-items: center;
  padding: var(--spacing-xl); gap: var(--spacing-sm);
}
.loading-dots { display: flex; gap: 8rpx; }
.dot {
  width: 12rpx; height: 12rpx; background: var(--color-accent);
  border-radius: 6rpx;
}
.load-end {
  padding: var(--spacing-lg); font-size: var(--font-size-footnote);
  color: var(--color-text-tertiary); text-align: center;
}
.bottom-spacer {
  height: calc(var(--tabbar-height) + var(--safe-area-bottom) + var(--spacing-lg));
}
