<!--
  首页 — 美甲DIY
  Apple HIG 风格 · 专业色板卡
-->
<view class="page-index">

  <!-- ====== 自定义导航栏 ====== -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="navbar-brand">
        <text class="brand-name">美甲DIY</text>
      </view>
    </view>
  </view>

  <!-- ====== 搜索栏 ====== -->
  <view class="search-section">
    <view class="search-box {{searchFocused ? 'focused' : ''}}">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索款式、风格、颜色..."
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        confirm-type="search"
      />
    </view>
    <view class="hot-keywords" wx:if="{{!searchFocused}}">
      <text class="hot-label">热门：</text>
      <text class="hot-keyword" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="onKeywordTap" data-keyword="{{item}}">{{item}}</text>
    </view>
    <view class="search-panel animate-fade-in" wx:if="{{showSearchResults && searchResults.length > 0}}">
      <view class="search-item" wx:for="{{searchResults}}" wx:key="_id" bindtap="onStyleTap" data-id="{{item._id}}">
        <view class="search-item-color" style="background: {{item.primaryColor}};"></view>
        <text class="search-item-name">{{item.name}}</text>
        <text class="search-item-tag">{{item.tags[0]}}</text>
      </view>
    </view>
  </view>

  <!-- ====== 主滚动区 ====== -->
  <scroll-view
    class="main-scroll" scroll-y enhanced show-scrollbar="{{false}}"
    bindscrolltolower="onReachBottom" refresher-enabled
    refresher-triggered="{{loading}}" bindrefresherrefresh="onPullDownRefresh"
  >

    <!-- ====== Hero Banner ====== -->
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(0,0,0,0.15)" indicator-active-color="var(--color-accent)" autoplay interval="4000" duration="500" circular bindchange="onBannerChange">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-card" style="background: {{item.gradient}};" bindtap="onBannerTap">
          <view class="banner-text">
            <text class="banner-emoji">{{item.emoji}}</text>
            <text class="banner-title">{{item.title}}</text>
            <text class="banner-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>

    <!-- ====== 快捷入口 ====== -->
    <view class="quick-entries">
      <view class="quick-entry animate-fade-in" wx:for="{{quickEntries}}" wx:key="id" bindtap="onQuickEntry" data-path="{{item.path}}">
        <view class="entry-icon-wrap" style="background: {{item.color}}12;">
          <text class="entry-icon">{{item.icon}}</text>
        </view>
        <text class="entry-label">{{item.label}}</text>
      </view>
    </view>

    <!-- ====== 热门款式横滑 ====== -->
    <view class="section" wx:if="{{hotStyles.length > 0}}">
      <view class="section-header">
        <text class="section-title">热门款式</text>
        <text class="section-more" bindtap="onQuickEntry" data-path="/pages/gallery/gallery">查看全部 →</text>
      </view>
      <scroll-view class="hot-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="hot-card animate-fade-in" wx:for="{{hotStyles}}" wx:key="_id" bindtap="onStyleTap" data-id="{{item._id}}">
          <view class="hot-card-img" style="background: {{item.colors[3] || item.colors[0]}}18;">
            <view class="hot-swatch-stack">
              <view class="hot-swatch" wx:for="{{item.colors}}" wx:for-item="c" wx:key="*this" wx:if="{{index < 3}}" style="background: {{c}};"></view>
            </view>
            <view class="hot-card-badge" wx:if="{{item.isHot}}"><text>HOT</text></view>
          </view>
          <view class="hot-card-info">
            <text class="hot-card-name text-ellipsis">{{item.name}}</text>
            <view class="hot-card-meta">
              <text class="hot-card-diff">{{item.categoryName}}</text>
              <text class="hot-card-likes">❤ {{item.likes}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ====== 分类标签 ====== -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">发现款式</text>
      </view>
      <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="category-tag {{activeCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-category="{{item.id}}">
          <text>{{item.icon}} {{item.name}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- ====== 款式网格 ====== -->
    <view class="style-grid">
      <view class="style-card animate-fade-in" wx:for="{{styles}}" wx:key="_id" bindtap="onStyleTap" data-id="{{item._id}}">
        <view class="style-card-preview" style="background: {{item.colors[3] || item.colors[0]}}18;">
          <view class="style-swatch-stack">
            <view class="style-swatch" wx:for="{{item.colors}}" wx:for-item="c" wx:key="*this" wx:if="{{index < 4}}" style="background: {{c}};">
              <view class="style-swatch-shine"></view>
            </view>
          </view>
        </view>
        <view class="style-card-body">
          <text class="style-card-name text-ellipsis">{{item.name}}</text>
          <view class="style-card-footer">
            <view class="style-tags">
              <text class="style-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 2}}">{{tag}}</text>
            </view>
            <text class="style-likes">❤ {{item.likes}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{loading}}">
      <view class="loading-dots"><view class="dot"></view><view class="dot"></view><view class="dot"></view></view>
      <text class="text-tertiary">发现更多款式...</text>
    </view>
    <view class="load-end" wx:if="{{!hasMore && styles.length > 0}}">— 已加载全部款式 —</view>
    <view class="bottom-spacer"></view>
  </scroll-view>
</view>
